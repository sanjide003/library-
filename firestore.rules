rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isEnabledUser() { return signedIn() && userDoc().data.status != 'blocked'; }
    function isAdmin() { return isEnabledUser() && userDoc().data.role == 'admin'; }
    function isOwner(uid) { return signedIn() && request.auth.uid == uid; }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /books/{bookId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isAdmin() || isOwner(uid);
      allow create: if signedIn() && (isAdmin() || isOwner(uid));
      allow update: if isAdmin() || (isOwner(uid)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['name'])
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status);
      allow delete: if false;
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin() || (isEnabledUser() && resource.data.userPhone == userDoc().data.phone);
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
